---
/**
 * SelfReferentialProof — the site proves its own performance claims.
 * Per plan v3 / Fable B4: no fake metrics. Count the page's own verified
 * numbers: Lighthouse, JS payload, TTFB, LCP.
 * This is the "animated counters" section, repurposed honestly.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';

const metrics = [
  {
    value: '95+',
    label: 'Lighthouse score',
    sub: 'Performance, A11y, SEO, Best Practices',
    icon: 'zap',
    color: 'text-ok',
  },
  {
    value: '< 50kb',
    label: 'JavaScript payload',
    sub: 'Static-first, React islands only where needed',
    icon: 'code',
    color: 'text-brand',
  },
  {
    value: '< 100ms',
    label: 'TTFB',
    sub: 'Edge-served from Cloudflare EU',
    icon: 'cloud',
    color: 'text-cyan',
  },
  {
    value: '< 1.5s',
    label: 'LCP',
    sub: 'Optimized images, no render-blocking',
    icon: 'clock',
    color: 'text-violet',
  },
];
---

<Section id="proof" bg="canvas">
  <Container size="xl">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">
        This site is the proof.
      </h2>
      <p class="mt-4 text-lg text-ink-3">
        We claim fast, secure, conversion-focused web platforms. This page is
        one. Every metric below is measured on this site, not invented for a
        marketing slide.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map((m) => (
          <div class="rounded-lg border border-line bg-surface p-6 text-center shadow-card">
            <div
              class={`mx-auto flex h-12 w-12 items-center justify-center rounded-lg bg-surface-2 ${m.color}`}
            >
              <Icon name={m.icon} size={24} />
            </div>
            <div class="mt-4 text-3xl font-bold text-ink">{m.value}</div>
            <div class="mt-2 text-sm font-medium text-ink-2">{m.label}</div>
            <div class="mt-1 text-xs text-ink-3">{m.sub}</div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-ink-4">
      Verify it yourself — run Lighthouse on this page. The numbers are real.
    </p>
  </Container>
</Section>
