---
/**
 * SelfReferentialProof — the site proves its own performance claims.
 * Per plan v3 / Fable B4: no fake metrics. Count the page's own verified
 * numbers: Lighthouse, JS payload, TTFB, LCP.
 * This is the "animated counters" section, repurposed honestly.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;

/**
 * No content file backs this section (see src/content/en|sk/*.ts) — the
 * metrics/copy below match the design spec verbatim and aren't otherwise
 * localized. This eyebrow is new copy, so it gets a real SK translation
 * rather than being left English-only.
 */
const eyebrowLabel = locale === 'sk' ? 'Dôkaz' : 'Proof';

const metrics = [
  {
    value: '95+',
    label: 'Lighthouse score',
    sub: 'Performance, A11y, SEO, Best Practices.',
    icon: 'zap',
    color: 'text-status-success',
  },
  {
    value: '< 50 KB',
    label: 'JavaScript payload',
    sub: 'Static-first, React islands only where needed.',
    icon: 'code',
    color: 'text-primary-500',
  },
  {
    value: '< 100 ms',
    label: 'TTFB',
    sub: 'Served from GCP Cloud Run.',
    icon: 'cloud',
    color: 'text-accent-cyan',
  },
  {
    value: '< 1.5 s',
    label: 'LCP',
    sub: 'Optimized images, no render-blocking.',
    icon: 'clock',
    color: 'text-accent-violet',
  },
];
---

<Section id="proof" bg="canvas">
  <Container size="xl">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <Eyebrow index={8} label={eyebrowLabel} class="mb-4" />
      <h2
        class="text-3xl font-bold tracking-tight text-(--color-text-primary) md:text-4xl"
      >
        This site is the proof.
      </h2>
      <p class="mt-4 text-lg text-(--color-text-secondary)">
        We claim fast, secure, conversion-focused web platforms. This page is
        one. Every metric below is measured on this site, not invented for a
        marketing slide.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map((m) => (
          <div class="rounded-lg border border-(--color-border-subtle) bg-surface-raised p-6 text-center shadow-card">
            <div
              class={`mx-auto flex h-12 w-12 items-center justify-center rounded-lg bg-surface-sunken ${m.color}`}
            >
              <Icon name={m.icon} size={24} />
            </div>
            <div class="mt-4 text-3xl font-bold text-(--color-text-primary)">
              {m.value}
            </div>
            <div class="mt-2 text-sm font-medium text-(--color-text-secondary)">
              {m.label}
            </div>
            <div class="mt-1 text-xs text-(--color-text-secondary)">
              {m.sub}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-(--color-text-secondary)">
      Verify it yourself — run Lighthouse on this page. The numbers are real.
    </p>
  </Container>
</Section>
