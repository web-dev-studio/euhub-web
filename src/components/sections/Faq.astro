---
/**
 * FAQ — native <details>/<summary> accordion.
 * Per plan v3: no React island for FAQ; native HTML is accessible by default.
 * 12 items (10 from prompt + 2 engagement/pricing orientation).
 *
 * Also emits FAQPage JSON-LD (a second `application/ld+json` block,
 * separate from BaseLayout's Organization/ProfessionalService graph) built
 * directly from the same `faq` array that renders the visible
 * <details>/<summary> markup below, so the structured data always matches
 * the on-page content exactly — a hard requirement for FAQPage rich results.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { faq } = getContent(locale).faq;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Section id="faq" bg="canvas">
  <Container size="md">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <Eyebrow index={10} label="FAQ" class="mb-4" />
      <h2
        class="font-heading text-h2 font-bold tracking-tight text-(--color-text-primary)"
      >
        Frequently asked questions
      </h2>
      <p class="mt-4 text-lead text-(--color-text-secondary)">
        Direct answers. No agency-speak.
      </p>
    </div>

    <div class="mt-12 space-y-3">
      {
        faq.map((item) => (
          <details class="group rounded-lg border border-(--color-border-subtle) bg-surface-raised px-6 py-1 shadow-card">
            <summary class="flex cursor-pointer items-center justify-between gap-4 py-4 font-medium text-(--color-text-primary) marker:content-none">
              <span>{item.question}</span>
              <span
                class="mt-0.5 shrink-0 font-mono text-xl text-primary-500 transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <div class="pb-5 text-sm leading-relaxed text-(--color-text-secondary)">
              {item.answer}
            </div>
          </details>
        ))
      }
    </div>
  </Container>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
  />
</Section>
