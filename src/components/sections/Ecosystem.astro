---
/**
 * Ecosystem — 5 EUHUB brand cards.
 * Per plan v3 / Fable B7: positioned BELOW the CTA/form (not before it).
 * All outbound links open in new tabs. The self-referential "This site"
 * card (Build with EUHub) has no `url` — per the design brief it must not
 * link out, and is visually distinguished with a primary/40 border instead
 * of the default subtle border the linked cards use.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { eyebrow, ecosystem } = getContent(locale).ecosystem;
---

<Section id="ecosystem" bg="surface-2">
  <Container>
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <Eyebrow index={9} label={eyebrow} class="mb-4" />
      <h2
        class="font-heading text-h2 font-bold tracking-tight text-(--color-text-primary)"
      >
        Part of the EUHUB engineering ecosystem
      </h2>
      <p class="mt-4 text-lead text-(--color-text-secondary)">
        Build with EUHub is the web engineering unit. The wider ecosystem covers
        AI, consulting, and community — so your project has depth behind it.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        ecosystem.map((brand) =>
          brand.url ? (
            <a
              href={brand.url}
              target="_blank"
              rel="noopener"
              class="group flex flex-col rounded-lg border border-(--color-border-subtle) bg-surface-raised p-6 shadow-card transition-all hover:shadow-raised hover:border-(--color-border-default)"
              data-umami-event="ecosystem_link_click"
              data-umami-brand={brand.id}
            >
              <div class="flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-primary-50 to-secondary-500/10 text-primary-500">
                  <Icon name="layers" size={20} />
                </div>
                <Icon
                  name="external"
                  size={14}
                  class="text-(--color-text-secondary) transition-colors group-hover:text-primary-500"
                />
              </div>
              <h3 class="mt-4 font-heading text-base font-semibold text-(--color-text-primary)">
                {brand.name}
              </h3>
              <div class="mt-1 text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">
                {brand.role}
              </div>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-(--color-text-secondary)">
                {brand.description}
              </p>
              <div class="mt-4 flex items-center gap-1 text-sm font-medium text-primary-500">
                Visit {brand.name} <span aria-hidden="true">↗</span>
              </div>
            </a>
          ) : (
            <div class="group flex flex-col rounded-lg border border-primary-500/40 bg-surface-raised p-6 shadow-card">
              <div class="flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-primary-50 to-secondary-500/10 text-primary-500">
                  <Icon name="layers" size={20} />
                </div>
              </div>
              <h3 class="mt-4 font-heading text-base font-semibold text-(--color-text-primary)">
                {brand.name}
              </h3>
              <div class="mt-1 text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">
                {brand.role}
              </div>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-(--color-text-secondary)">
                {brand.description}
              </p>
            </div>
          ),
        )
      }
    </div>
  </Container>
</Section>
