---
/**
 * Tech Stack — categorized grid, not a logo wall.
 * Proves engineering depth across 5 categories.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { techStack } = getContent(locale).techStack;
---

<Section id="tech-stack" bg="surface-2">
  <Container size="xl">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2
        class="text-3xl font-bold tracking-tight text-(--color-text-primary) md:text-4xl"
      >
        Built with modern engineering standards
      </h2>
      <p class="mt-4 text-lg text-(--color-text-secondary)">
        We choose tools based on what your project needs, not what is trending.
        Here is the stack we reach for most often.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        techStack.map((category) => (
          <div class="rounded-lg border border-(--color-border-subtle) bg-surface-raised p-6 shadow-card">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-500">
                <Icon name={category.icon} size={20} />
              </div>
              <h3 class="text-base font-semibold text-(--color-text-primary)">
                {category.title}
              </h3>
            </div>
            <ul class="mt-4 space-y-2">
              {category.items.map((item) => (
                <li class="flex items-center gap-2 text-sm text-(--color-text-secondary)">
                  <span class="h-1.5 w-1.5 rounded-full bg-primary-500" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
