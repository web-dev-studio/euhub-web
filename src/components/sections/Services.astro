---
/**
 * Services — 7 service cards with hover interactions (desktop only).
 * Maps business needs to offers.
 *
 * Eyebrow is "03 // What we build" (index 3, matching this section's
 * position in the render order); the H2 is the "Each service is
 * engineered..." sentence with no separate lead paragraph, per spec. Each
 * card leads with a mono "NN // Tag" index label instead of an icon box.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';
import Icon from '../ui/Icon.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { eyebrow, services } = getContent(locale).services;
---

<Section id="services" bg="canvas">
  <Container>
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <Eyebrow index={3} label={eyebrow} class="mb-4" />
      <h2
        class="font-heading text-h2 font-extrabold tracking-tight text-(--color-text-primary)"
      >
        Each service is engineered for a specific business need — not a template
        filled with your logo.
      </h2>
    </div>

    <div
      class="mt-16 grid grid-cols-[repeat(auto-fit,minmax(340px,1fr))] gap-6"
      data-reveal
    >
      {
        services.map((service, i) => (
          <a
            href="#contact"
            class="group"
            data-umami-event="service_card_click"
            data-umami-service={service.id}
          >
            <Card hover padding="lg" class="h-full">
              <p class="font-mono text-sm font-semibold tracking-[0.1em] text-primary-500 uppercase">
                {String(i + 1).padStart(2, '0')} // {service.tag}
              </p>
              <h3 class="mt-4 font-heading text-lg font-semibold text-(--color-text-primary)">
                {service.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
                {service.summary}
              </p>
              <ul class="mt-4 space-y-2">
                {service.includes.map((item) => (
                  <li class="flex items-center gap-2 text-xs text-(--color-text-secondary)">
                    <Icon name="check" size={14} class="text-status-success" />
                    {item}
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-1 text-sm font-medium text-primary-500 opacity-0 transition-opacity group-hover:opacity-100">
                Request audit
                <Icon name="arrow-right" size={16} />
              </div>
            </Card>
          </a>
        ))
      }
    </div>
  </Container>
</Section>
