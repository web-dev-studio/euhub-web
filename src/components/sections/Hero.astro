---
/**
 * Hero — restyled to match grow (euhub-marketing)'s current hero layout:
 * a grid-pattern background layer plus a radial-gradient glow layer behind
 * a Container-wrapped intro, no page-level divider under the section.
 *
 * Two-column grid (copy + a bordered list of stats), matching both grow's
 * layout and the "Build with EUHUB Landing" design brief's hero — which
 * pairs the pitch with a small panel of build-quality metrics (Lighthouse,
 * JS payload, TTFB, LCP) rather than marketing-style stats. Build's own
 * headline, subheadline, CTAs, and trust line are unchanged.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { primaryCta, secondaryCta, trustLine, heroStats } =
  getContent(locale).site;
---

<Section bg="canvas" padding="lg" class="relative overflow-hidden">
  {/* Subtle grid-pattern background layer */}
  <div
    aria-hidden="true"
    class="bg-grid pointer-events-none absolute inset-0 opacity-40"
  >
  </div>
  {/* Radial-gradient glow layer */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0"
    style="background-image: radial-gradient(circle at 12% 20%, var(--color-primary-glow), transparent 30%), radial-gradient(circle at 88% 8%, var(--color-secondary-glow), transparent 30%);"
  >
  </div>

  <Container size="xl" class="relative grid gap-12 lg:grid-cols-[1.5fr_0.5fr]">
    <div>
      <Badge variant="brand">
        <Icon name="zap" size={12} />
        Web engineering studio · EUHUB
      </Badge>

      <h1
        class="mt-6 text-4xl font-bold leading-tight tracking-tight text-(--color-text-primary) md:text-5xl lg:text-[2.75rem]"
      >
        Premium websites, web apps, and AI-ready interfaces for European
        businesses.
      </h1>

      <p
        class="mt-6 max-w-xl text-lg leading-relaxed text-(--color-text-secondary)"
      >
        Web Dev Studio by EUHUB designs and engineers modern websites, landing
        pages, dashboards, client portals, and AI-integrated web applications
        with performance, security, and business logic built in from day one.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button
          href={primaryCta.href}
          size="lg"
          data-umami-event="cta_primary_click"
        >
          {primaryCta.label}
          <Icon name="arrow-right" size={18} />
        </Button>
        <Button
          href={secondaryCta.href}
          variant="secondary"
          size="lg"
          data-umami-event="cta_secondary_click"
        >
          {secondaryCta.label}
        </Button>
      </div>

      <p
        class="mt-8 flex items-center gap-2 text-sm text-(--color-text-secondary)"
      >
        <Icon name="shield" size={16} class="text-status-success" />
        {trustLine}
      </p>
    </div>

    <div class="flex flex-col border-l border-(--color-border-subtle) pl-8">
      {
        heroStats.map((stat) => (
          <div class="border-b border-(--color-border-subtle) py-[18px] last:border-b-0">
            <p class="mb-1.5 font-mono text-[11px] tracking-[0.2em] text-(--color-text-secondary) uppercase">
              {stat.label}
            </p>
            <p class="font-mono text-[19px] font-semibold text-(--color-primary-500)">
              {stat.value}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
