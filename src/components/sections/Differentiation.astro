---
/**
 * Differentiation — "Design is only the visible layer."
 * 5-layer stack visual proving engineering-led approach.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;

/**
 * No content file backs this section (see src/content/en|sk/*.ts) — the
 * layer copy below matches the design spec verbatim and isn't otherwise
 * localized. This eyebrow is new copy, so it gets a real SK translation
 * (mirroring grow/euhub-marketing's own "The stack" -> "Vrstvy systému")
 * rather than being left English-only.
 */
const eyebrowLabel = locale === 'sk' ? 'Vrstvy systému' : 'The stack';

const layers = [
  {
    n: 1,
    title: 'Visual interface',
    desc: 'UX design, UI patterns, responsive layout, accessibility',
    icon: 'layout',
    color: 'text-primary-500',
    bg: 'bg-primary-50',
  },
  {
    n: 2,
    title: 'Business logic',
    desc: 'Workflows, rules, validation, user flows, conversion structure',
    icon: 'code',
    color: 'text-accent-cyan',
    bg: 'bg-accent-cyan/10',
  },
  {
    n: 3,
    title: 'API integrations',
    desc: 'CRM, ERP, payment, email, logistics, internal databases',
    icon: 'plug',
    color: 'text-accent-violet',
    bg: 'bg-accent-violet/10',
  },
  {
    n: 4,
    title: 'Data and automation',
    desc: 'Analytics, tracking, automation pipelines, AI-ready infrastructure',
    icon: 'zap',
    color: 'text-status-warning',
    bg: 'bg-status-warning-bg',
  },
  {
    n: 5,
    title: 'Hosting, monitoring, security',
    desc: 'CI/CD, uptime, backups, GDPR-aware architecture, EU data residency',
    icon: 'shield',
    color: 'text-status-success',
    bg: 'bg-status-success-bg',
  },
];
---

<Section id="differentiation" bg="surface-2">
  <Container>
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <Eyebrow index={4} label={eyebrowLabel} class="mb-4" />
      <h2
        class="font-heading text-h2 font-extrabold tracking-tight text-(--color-text-primary)"
      >
        Design is only the visible layer.
      </h2>
      <p class="mt-4 text-lead text-(--color-text-secondary)">
        A serious website is not a brochure. It is part of your business
        infrastructure. We engineer all five layers, not just the one visitors
        see.
      </p>
    </div>

    {/* Layered visual */}
    <div class="mx-auto mt-16 max-w-2xl space-y-3">
      {
        layers.map((layer) => (
          <div
            class={`flex items-center gap-4 rounded-lg border bg-surface-raised p-5 shadow-card ${
              layer.n === 1
                ? 'border-primary-500/40'
                : 'border-(--color-border-subtle)'
            }`}
          >
            <div
              class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-lg ${layer.bg} ${layer.color}`}
            >
              <Icon name={layer.icon} size={24} />
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-mono text-xs font-semibold text-primary-500">
                  L{layer.n}
                </span>
                <h3 class="font-heading text-base font-semibold text-(--color-text-primary)">
                  {layer.title}
                </h3>
              </div>
              <p class="mt-1 text-sm text-(--color-text-secondary)">
                {layer.desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mx-auto mt-12 max-w-2xl rounded-lg border border-primary-500/20 bg-primary-50 p-6 text-center"
    >
      <p class="text-lg font-medium text-primary-500">
        UX design + front-end engineering + API integration + AI-readiness +
        DevOps. One team, five layers, one system.
      </p>
    </div>
  </Container>
</Section>
