---
/**
 * Engagement Models — pricing shapes (not another service list).
 * Per plan v3 / Fable B6: describes HOW you buy, not WHAT you buy.
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { engagementModels, pricingOrientationCopy } =
  getContent(locale).engagement;
const { primaryCta } = getContent(locale).site;
---

<Section id="pricing" bg="surface-2">
  <Container>
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2
        class="font-heading text-h2 font-extrabold tracking-tight text-(--color-text-primary)"
      >
        How you can work with us
      </h2>
      <p class="mt-4 text-lead text-(--color-text-secondary)">
        {pricingOrientationCopy}
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        engagementModels.map((model, i) => (
          <div
            class={`relative flex flex-col rounded-lg border p-8 shadow-card ${
              i === 1
                ? 'border-primary-500 bg-surface-raised ring-2 ring-primary-500/20'
                : 'border-(--color-border-subtle) bg-surface-raised'
            }`}
          >
            {i === 1 && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <Badge variant="brand">Most common</Badge>
              </div>
            )}

            <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-(--color-text-secondary)">
              <Icon
                name={i === 0 ? 'search' : i === 1 ? 'layers' : 'refresh'}
                size={14}
                class="text-primary-500"
              />
              {i === 0 ? 'Entry point' : i === 1 ? 'Project' : 'Ongoing'}
            </div>

            <h3 class="mt-4 font-heading text-xl font-bold text-(--color-text-primary)">
              {model.shape}
            </h3>

            <p class="mt-3 text-sm leading-relaxed text-(--color-text-secondary)">
              {model.howItWorks}
            </p>

            <div class="mt-6 border-t border-(--color-border-subtle) pt-6">
              <div class="text-xs font-medium uppercase tracking-wider text-(--color-text-secondary)">
                Price orientation
              </div>
              <div class="mt-1 text-lg font-bold text-primary-500">
                {model.priceOrientation}
              </div>
              <div class="mt-2 text-xs text-(--color-text-secondary)">
                {model.typicalScope}
              </div>
            </div>

            <div class="mt-8">
              <Button
                href={primaryCta.href}
                variant={i === 1 ? 'primary' : 'secondary'}
                size="md"
                class="w-full"
                data-umami-event="cta_primary_click"
              >
                {i === 0 ? 'Request audit' : 'Start a conversation'}
              </Button>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
