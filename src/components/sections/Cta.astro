---
/**
 * CTA — "Start with a technical web audit."
 * Contains the audit offer copy + the contact form (React island).
 * Per plan v3: form is a React island with Turnstile + webhook + mailto fallback.
 * Privacy notice at the form (Art. 13 point-of-collection).
 */
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import AuditRequestForm from '../forms/AuditRequestForm.tsx';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { site } = getContent(locale).site;
---

<Section id="contact" bg="surface-2" padding="lg">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
      {/* Copy side */}
      <div>
        <Eyebrow index={11} label="Contact" class="mb-4" />
        <h2
          class="font-heading text-h2 font-extrabold tracking-tight text-(--color-text-primary)"
        >
          Start with a technical web audit.
        </h2>
        <p class="mt-6 text-lead leading-relaxed text-(--color-text-secondary)">
          We will review your current website, positioning, speed, structure,
          conversion flow, integrations, and technical risks. You get a clear
          list of what to fix, what to rebuild, and what is not worth touching.
        </p>

        <div class="mt-8 space-y-4">
          {
            [
              'Performance, SEO, and accessibility baseline',
              'Conversion structure and UX review',
              'Technical stack and integration assessment',
              'Prioritized action list — what to fix, rebuild, or ignore',
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-status-success-bg text-status-success">
                  <Icon name="check" size={14} />
                </div>
                <p class="text-sm leading-relaxed text-(--color-text-secondary)">
                  {item}
                </p>
              </div>
            ))
          }
        </div>

        <div
          class="mt-8 rounded-lg border border-(--color-border-subtle) bg-surface-raised p-5"
        >
          <p class="text-sm text-(--color-text-secondary)">
            Prefer email? Write to us directly at{' '}
            <a
              href={`mailto:${site.contactEmail}`}
              class="font-medium text-primary-500 hover:underline"
              data-umami-event="email_click"
            >
              {site.contactEmail}
            </a>
          </p>
        </div>
      </div>

      {/* Form side */}
      <div>
        <div
          id="audit-form-container"
          class="rounded-xl border border-(--color-glass-border) bg-(--color-glass-bg) p-6 shadow-raised backdrop-blur-md md:p-8"
        >
          <AuditRequestForm
            turnstileSiteKey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
            contactEmail={site.contactEmail}
            locale={locale}
            client:load
          />

          {/* Privacy notice (Art. 13 point-of-collection) */}
          <p class="mt-4 text-xs leading-relaxed text-(--color-text-secondary)">
            By submitting this form, you agree that we may process your data to
            respond to your request. We use cookieless analytics and do not sell
            your data. See our{' '}
            <a href="/privacy/" class="text-primary-500 hover:underline">
              Privacy Policy
            </a>
            .
          </p>
        </div>
      </div>
    </div>
  </Container>
</Section>
