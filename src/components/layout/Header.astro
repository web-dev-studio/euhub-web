---
/**
 * Header — structurally identical to grow's (euhub-marketing) and deploy's
 * (euhub-deploy) `Header.astro`: thin utility bar above the main header,
 * 3-column centered-nav grid (`grid-cols-[1fr_auto_1fr]`), typing-cursor
 * wordmark, mobile menu. Content substituted for build's own identity
 * (wordmark "BUILD", build's own nav items and CTA copy — sourced from
 * `site.nav` / `primaryCta`, already the right shape, no new content
 * fields needed).
 *
 * Ecosystem links (`site.ecosystemLinks`) are intentionally NOT rendered
 * here — matching grow/deploy, neither of which shows ecosystem links in
 * the header. Build has its own dedicated `<Ecosystem />` section
 * (src/components/sections/Ecosystem.astro, wired into both locale home
 * pages below the CTA) that covers this, so `site.ecosystemLinks` is left
 * defined but unused rather than deleted (same "leave unused content,
 * don't delete" approach used for deploy's now-dead `site.badge`).
 *
 * Accessibility labels below are plain English literals, not sourced from
 * a `site.a11y` bundle — build has no such bundle (see ThemeSelector.astro,
 * which made the same call for its own labels), and these strings are
 * carried over unchanged from the previous single-tier header rather than
 * inventing new copy or new i18n scaffolding as a side effect of this
 * structural port.
 */
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import ThemeSelector from '../ui/ThemeSelector.astro';
import LanguageSwitch from '../ui/LanguageSwitch.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { site, primaryCta, trustLine } = getContent(locale).site;
const homeHref = locale === 'sk' ? '/sk/' : '/';
---

<div
  class="border-b border-(--color-border-subtle) font-mono text-[11px] tracking-[0.12em]"
>
  <Container class="flex h-9 items-center justify-between">
    <span class="hidden uppercase text-(--color-text-secondary) sm:inline">
      {trustLine}
    </span>
    <div class="flex items-center gap-2 sm:gap-4">
      <LanguageSwitch locale={locale} />
      <ThemeSelector />
    </div>
  </Container>
</div>

<header
  class="sticky top-0 z-50 h-(--spacing-header-height) border-b border-(--color-border-subtle) bg-(--color-surface-page)/80 backdrop-blur-md"
>
  <Container
    class="grid h-full grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-4"
  >
    <a
      href={homeHref}
      aria-label="Build with EUHub — home"
      class="flex min-w-0 items-center gap-2.5 whitespace-nowrap justify-self-start"
    >
      <span
        aria-hidden="true"
        class="inline-block h-9 w-1 shrink-0 rounded-full bg-gradient-to-b from-(--color-primary-500) to-(--color-secondary-500) shadow-(--shadow-glow-primary)"
      ></span>
      <span class="flex flex-col leading-tight">
        <span class="flex items-center">
          <span
            class="inline-block overflow-hidden whitespace-nowrap align-bottom font-mono text-[17px] font-semibold uppercase tracking-[0.04em]"
            style="animation: ds-type 2.8s steps(5,end) infinite alternate;"
          >
            BUILD
          </span>
          <span
            aria-hidden="true"
            class="ml-0.5 inline-block h-[17px] w-2 animate-flow-pulse bg-(--color-primary-500)"
          ></span>
        </span>
        <span
          class="font-mono text-[9.5px] uppercase tracking-[0.3em] text-(--color-primary-500)"
        >
          with EUHUB
        </span>
      </span>
    </a>

    <nav
      aria-label="Primary navigation"
      class="hidden items-center gap-7 justify-self-center md:flex"
    >
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="border-b-2 border-transparent pb-1.5 text-sm font-medium text-(--color-text-primary) hover:border-(--color-primary-500) hover:text-(--color-primary-500)"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-1.5 justify-self-end sm:gap-4">
      <!--
        The CTA is always rendered here, outside the JS-gated mobile panel,
        so it stays visible/usable on mobile even if JS never runs.
      -->
      <Button
        href={primaryCta.href}
        variant="primary"
        size="sm"
        class="px-2 text-xs sm:px-5 sm:text-sm"
        data-umami-event="cta_primary_click"
      >
        {primaryCta.label}
      </Button>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="menu" class="menu-icon-open" />
        <Icon name="close" class="menu-icon-close hidden" />
      </button>
    </div>
  </Container>

  <div
    id="mobile-menu"
    class="hidden border-t border-(--color-border-subtle) bg-(--color-surface-raised) md:hidden"
  >
    <Container class="flex flex-col gap-4 py-4">
      <nav
        aria-label="Mobile navigation"
        class="flex flex-col gap-3"
        data-mobile-nav
      >
        {
          site.nav.map((item) => (
            <a
              href={item.href}
              class="text-base font-medium text-(--color-text-primary)"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const openIcon = toggle.querySelector('.menu-icon-open');
    const closeIcon = toggle.querySelector('.menu-icon-close');

    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      menu.classList.toggle('hidden', !open);
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    menu.querySelectorAll('[data-mobile-nav] a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        toggle.getAttribute('aria-expanded') === 'true'
      ) {
        setOpen(false);
        toggle.focus();
      }
    });
  }
</script>
