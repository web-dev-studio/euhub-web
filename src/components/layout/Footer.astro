---
/**
 * Footer — wordmark, description, nav, ecosystem links,
 * contact, location, legal pages, copyright.
 *
 * Per plan v3:
 *  - Ecosystem links open in new tabs
 *  - Legal pages: /privacy/, /cookies/, /terms/
 *  - No SK language switch
 */
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import LanguageSwitch from '../ui/LanguageSwitch.astro';
import { getContent } from '../../lib/i18n';
import type { Locale } from '../../content/types';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const { site } = getContent(locale).site;
const { ecosystem } = getContent(locale).ecosystem;

const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-surface">
  <Container size="xl">
    <div class="grid gap-12 py-16 md:py-20 lg:grid-cols-4">
      {/* Brand + description */}
      <div class="lg:col-span-1">
        <div class="flex items-baseline gap-1.5 font-bold text-ink">
          <span class="text-lg">{site.wordmark}</span>
          <span class="text-xs font-medium text-ink-3">{site.tagline}</span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-ink-3">
          Fast, secure, conversion-focused web platforms for European
          businesses. Engineering-led, GDPR-aware, maintained long-term.
        </p>
      </div>

      {/* Navigation */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-4">
          Navigation
        </h2>
        <ul class="mt-4 space-y-3">
          {
            site.nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-ink-2 hover:text-brand transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* EUHUB ecosystem */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-4">
          EUHUB Ecosystem
        </h2>
        <ul class="mt-4 space-y-3">
          {
            ecosystem.map((brand) => (
              <li>
                <a
                  href={brand.url}
                  target="_blank"
                  rel="noopener"
                  class="flex items-center gap-1.5 text-sm text-ink-2 hover:text-brand transition-colors"
                >
                  {brand.name}
                  <Icon name="external" size={12} />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Contact + legal */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-4">
          Contact
        </h2>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href={`mailto:${site.contactEmail}`}
              class="flex items-center gap-2 text-sm text-ink-2 hover:text-brand transition-colors"
              data-umami-event="email_click"
            >
              <Icon name="mail" size={16} />
              {site.contactEmail}
            </a>
          </li>
          <li class="flex items-center gap-2 text-sm text-ink-3">
            <Icon name="globe" size={16} />
            {site.location}
          </li>
        </ul>
        <h2
          class="mt-6 text-xs font-semibold uppercase tracking-wider text-ink-4"
        >
          Legal
        </h2>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href="/privacy/"
              class="text-sm text-ink-2 hover:text-brand transition-colors"
            >
              Privacy Policy
            </a>
          </li>
          <li>
            <a
              href="/cookies/"
              class="text-sm text-ink-2 hover:text-brand transition-colors"
            >
              Cookie Policy
            </a>
          </li>
          <li>
            <a
              href="/terms/"
              class="text-sm text-ink-2 hover:text-brand transition-colors"
            >
              Terms of Service
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-line py-6">
      <div
        class="flex flex-col items-center justify-between gap-4 text-xs text-ink-4 sm:flex-row"
      >
        <p>
          &copy; {year} Web Dev Studio by EUHUB. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          <LanguageSwitch locale={locale} />
          <p>Part of the EUHUB engineering ecosystem.</p>
        </div>
      </div>
    </div>
  </Container>
</footer>
