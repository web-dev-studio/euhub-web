---
/**
 * LanguageSwitch — EN | SK language toggle, styled to match grow's/deploy's
 * pill-group pattern exactly (rounded border + background, active option
 * highlighted). Links point to the same page in the other locale (via
 * getAlternatePath). Clicking sets localStorage('i18n-choice') to override
 * auto-detection.
 *
 * Placement:
 *  - Desktop: Header next to ThemeSelector
 *  - Mobile: inside the mobile menu panel (not the sticky header row)
 *  - Also in Footer
 */
import type { Locale } from '../../content/types';
import { getAlternatePath } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

/**
 * Language names are locale-invariant literal text (a language's own name
 * doesn't translate), so these are static labels, not content-bundle
 * strings — same convention as grow's/deploy's LanguageSwitch.
 */
const options: { code: Locale; label: string; name: string }[] = [
  { code: 'en', label: 'EN', name: 'English' },
  { code: 'sk', label: 'SK', name: 'Slovenčina' },
];
---

<div
  class="inline-flex items-center gap-0.5 rounded-full border border-(--color-border-subtle) bg-(--color-surface-raised) p-0.5"
  data-language-switch
>
  {
    options.map((option) => (
      <a
        href={
          option.code === locale
            ? Astro.url.pathname
            : getAlternatePath(Astro.url, option.code)
        }
        aria-current={option.code === locale ? 'true' : undefined}
        aria-label={option.name}
        title={option.name}
        data-locale={option.code}
        class="inline-flex h-8 min-w-8 items-center justify-center rounded-full px-2 font-mono text-sm font-medium text-(--color-text-secondary) transition-colors hover:text-primary-500 aria-[current]:bg-(--color-surface-sunken) aria-[current]:font-semibold aria-[current]:text-primary-500"
      >
        {option.label}
      </a>
    ))
  }
</div>

<script>
  // Delegated on `document` (not per-instance) — this component can render
  // more than once per page (header desktop + mobile panel + footer); Astro
  // dedupes the identical inline script to one copy, and delegation still
  // catches clicks from every rendered instance.
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const link = target.closest<HTMLAnchorElement>(
      '[data-language-switch] a[data-locale]',
    );
    if (!link) return;
    const targetLocale = link.dataset.locale;
    if (!targetLocale) return;
    try {
      localStorage.setItem('i18n-choice', targetLocale);
    } catch {
      // Storage unavailable (private browsing, quota) — navigation still
      // proceeds via the plain href; only persistence is lost.
    }
  });
</script>
