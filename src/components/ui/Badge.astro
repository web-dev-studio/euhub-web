---
/**
 * Badge — small label for tags, labels, or status indicators.
 */
interface Props {
  variant?: 'default' | 'brand' | 'ok' | 'warn';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default:
    'bg-surface-sunken text-(--color-text-secondary) border border-(--color-border-subtle)',
  brand: 'bg-primary-50 text-primary-500 border border-primary-500/20',
  ok: 'bg-status-success-bg text-status-success border border-status-success/20',
  warn: 'bg-status-warning-bg text-status-warning border border-status-warning/20',
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium ${variants[variant]} ${className}`}
>
  <slot />
</span>
