---
/**
 * Button — primary, secondary, or ghost variant.
 * Renders as <a> when href is provided, <button> otherwise.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit';
  class?: string;
  'data-umami-event'?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  target,
  rel,
  type = 'button',
  class: className = '',
  'data-umami-event': umamiEvent,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full font-medium transition-[transform,background-color,border-color] duration-300 ease-(--ease-emphasis) focus-visible:outline-2 focus-visible:outline-(--color-focus-ring) focus-visible:outline-offset-2 disabled:opacity-50 disabled:pointer-events-none';

const variants = {
  primary:
    'bg-primary-500 text-(--color-text-on-primary) shadow-(--shadow-glow-primary) hover:-translate-y-0.5',
  secondary:
    'border border-(--color-text-secondary) text-(--color-text-primary) hover:border-(--color-text-primary)',
  ghost: 'text-(--color-text-primary) hover:bg-surface-sunken',
};

const sizes = {
  sm: 'text-sm px-5 py-2',
  md: 'text-base px-8 py-3.5',
  lg: 'text-lg px-9 py-4',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const attrs = {
  href,
  target,
  rel: rel ?? (target === '_blank' ? 'noopener' : undefined),
  type: href ? undefined : type,
  'data-umami-event': umamiEvent,
};
---

{
  href ? (
    <a class={classes} {...attrs}>
      <slot />
    </a>
  ) : (
    <button class={classes} {...attrs}>
      <slot />
    </button>
  )
}
