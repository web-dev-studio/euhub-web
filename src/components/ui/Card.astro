---
/**
 * Card — bordered surface with soft shadow, rounded corners.
 */
interface Props {
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { hover = false, padding = 'md', class: className = '' } = Astro.props;

const padMap = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const hoverClass = hover
  ? 'transition-all duration-200 hover:shadow-raised hover:border-(--color-border-default)'
  : '';
---

<div
  class={`rounded-lg border border-(--color-border-subtle) bg-surface-raised shadow-card ${padMap[padding]} ${hoverClass} ${className}`}
>
  <slot />
</div>
