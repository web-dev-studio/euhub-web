---
/**
 * BaseLayout — HTML shell for Web Dev Studio by EUHUB.
 * Plus Jakarta Sans / DM Sans / JetBrains Mono via Fontsource (self-hosted, no
 * Google Fonts) — the shared EUHUB type system.
 * SEO metadata, OG/Twitter, JSON-LD, Umami, skip link, and global styles.
 *
 * Props:
 *  - title:       <title> text (suffixed with brand)
 *  - description: meta description
 *  - path:        canonical path (e.g. "/"); full URL derived from astro.site
 *  - locale:      'en' | 'sk' — sets <html lang>, og:locale, hreflang alternates
 *  - noindex:     set true on legal placeholder pages during review
 *  - ogImage:     path to OG image (defaults to /og.png or /sk/og.png)
 */
import type { Locale } from '../content/types';
import { getAlternatePath } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  path: string;
  locale?: Locale;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  path,
  locale = 'en',
  noindex = false,
  ogImage = locale === 'sk' ? '/sk/og.png' : '/og.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://build.euhub.co');
const canonical = new URL(path, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const fullTitle =
  title === 'Web Dev Studio by EUHUB'
    ? title
    : `${title} — Web Dev Studio by EUHUB`;

// hreflang alternate URLs
const alternateEn = new URL(
  getAlternatePath(new URL(path, siteUrl), 'en'),
  siteUrl,
).href;
const alternateSk = new URL(
  getAlternatePath(new URL(path, siteUrl), 'sk'),
  siteUrl,
).href;

// Locale-specific metadata
const htmlLang = locale;
const ogLocale = locale === 'sk' ? 'sk_SK' : 'en_GB';

// Umami (cookieless, EU/Frankfurt). PUBLIC_ env vars are safe to inline.
const umamiScript = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

// JSON-LD: Organization + ProfessionalService (combined in one graph)
// Global styles — Tailwind v4 + the Fontsource typefaces (self-hosted)
import '../styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Web Dev Studio by EUHUB',
      url: siteUrl.href,
      inLanguage: locale,
      parentOrganization: {
        '@type': 'Organization',
        name: 'EUHUB.CO',
        url: 'https://euhub.co',
      },
      areaServed: 'EU',
      knowsAbout: [
        'Web development',
        'Web applications',
        'AI-integrated interfaces',
        'API integration',
        'DevOps',
      ],
    },
    {
      '@type': 'ProfessionalService',
      name: 'Web Dev Studio by EUHUB',
      url: siteUrl.href,
      areaServed: 'EU',
      serviceType: 'Web development, web applications, AI-ready interfaces',
      offers: {
        '@type': 'Offer',
        itemOffered: 'Technical Web Audit',
      },
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#006b70" />
    <meta name="generator" content={Astro.generator} />

    {
      /* No-FOUC theme bootstrap — ported from grow (euhub-marketing)'s
        BaseLayout.astro. Runs before paint to set html[data-theme]
        synchronously (avoids flash-of-wrong-theme). 'auto' resolves against
        prefers-color-scheme; 'light'/'dark' are explicit user choices.
        Mirrored by the equivalent runtime logic in the <script> at the
        bottom of <body>, which also handles live toggling + persistence —
        see ThemeSelector.astro for the UI this drives. */
    }
    <script is:inline>
      (() => {
        const storageKey = 'euhub-web-theme';
        const validModes = new Set(['auto', 'light', 'dark']);
        let mode = 'auto';

        try {
          const stored = localStorage.getItem(storageKey);
          if (stored && validModes.has(stored)) mode = stored;
        } catch {
          // Private browsing or storage policy: Auto safely falls back below.
        }

        const prefersDark =
          typeof window.matchMedia === 'function' &&
          window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved =
          mode === 'auto' ? (prefersDark ? 'dark' : 'light') : mode;
        const root = document.documentElement;
        root.dataset.theme = resolved;
        root.dataset.themeMode = mode;
        root.style.colorScheme = resolved;
      })();
    </script>

    {
      /*
      Auto-redirect Slovak browsers to /sk/ (EN pages only). The locale
      check is done inside the script (via document.documentElement.lang,
      already set synchronously by the <html lang> attribute above) rather
      than JSX-gating the <script> tag itself — prettier-plugin-astro can't
      parse a <script> wrapped in a `{cond && (...)}` expression.
    */
    }
    <script is:inline>
      (function () {
        if (document.documentElement.lang !== 'en') return;
        try {
          if (location.pathname.startsWith('/sk/')) return;
          if (localStorage.getItem('i18n-choice')) return;
          if (new URLSearchParams(location.search).has('no-redirect')) return;
          var langs = navigator.languages || [navigator.language];
          var isSk = langs.some(function (l) {
            return l.toLowerCase().startsWith('sk');
          });
          if (isSk) {
            localStorage.setItem('i18n-choice', 'sk');
            var skPath =
              '/sk' + location.pathname + location.search + location.hash;
            location.replace(skPath);
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>

    {/* Canonical + robots */}
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* hreflang alternate links */}
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="sk" href={alternateSk} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    {/* Primary meta */}
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Web Dev Studio by EUHUB" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD structured data */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    {/* Umami — cookieless analytics (EU/Frankfurt). Loaded with defer. */}
    {
      umamiScript && umamiId && (
        <script is:inline src={umamiScript} data-website-id={umamiId} defer />
      )
    }

    {/* Global styles are imported in the frontmatter (Tailwind v4 + fonts) */}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-md focus:bg-(--color-surface-raised) focus:px-4 focus:py-2 focus:shadow-card focus:ring-2 focus:ring-(--color-primary-500)"
    >
      Skip to content
    </a>
    <slot />

    {
      /* Theme toggle runtime — ported from grow (euhub-marketing)'s
        BaseLayout.astro. Drives any ThemeSelector.astro instance on the
        page via the data-theme-selector / data-theme-option contract;
        persists the mode so the pre-paint bootstrap script above picks it
        up on the next navigation. */
    }
    <script is:inline>
      (function () {
        var storageKey = 'euhub-web-theme';
        var validModes = ['auto', 'light', 'dark'];
        var root = document.documentElement;
        var mediaQuery =
          typeof window.matchMedia === 'function'
            ? window.matchMedia('(prefers-color-scheme: dark)')
            : null;

        function isValidMode(mode) {
          return validModes.indexOf(mode) !== -1;
        }

        function readThemeMode() {
          var mode = root.dataset.themeMode;
          return mode && isValidMode(mode) ? mode : 'auto';
        }

        function resolveTheme(mode) {
          if (mode === 'auto') {
            return mediaQuery && mediaQuery.matches ? 'dark' : 'light';
          }
          return mode;
        }

        function syncThemeSelectors(mode) {
          document
            .querySelectorAll('[data-theme-option]')
            .forEach(function (button) {
              var selected = button.dataset.themeOption === mode;
              button.setAttribute('aria-checked', String(selected));
              button.tabIndex = selected ? 0 : -1;
            });
        }

        function applyTheme(mode, persist) {
          var resolved = resolveTheme(mode);
          root.dataset.themeMode = mode;
          root.dataset.theme = resolved;
          root.style.colorScheme = resolved;
          syncThemeSelectors(mode);

          if (persist) {
            try {
              localStorage.setItem(storageKey, mode);
            } catch (e) {
              // The current page remains usable when storage is unavailable.
            }
          }
        }

        applyTheme(readThemeMode(), false);

        document.addEventListener('click', function (event) {
          var target = event.target;
          if (!(target instanceof Element)) return;
          var button = target.closest('[data-theme-option]');
          var mode = button && button.dataset.themeOption;
          if (!mode || !isValidMode(mode)) return;
          applyTheme(mode, true);
        });

        document.addEventListener('keydown', function (event) {
          var target = event.target;
          if (!(target instanceof HTMLButtonElement)) return;
          var selector = target.closest('[data-theme-selector]');
          if (!selector) return;

          var options = Array.prototype.slice.call(
            selector.querySelectorAll('[data-theme-option]'),
          );
          var index = options.indexOf(target);
          if (index === -1) return;

          var nextIndex = index;
          if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
            nextIndex = (index + options.length - 1) % options.length;
          } else if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
            nextIndex = (index + 1) % options.length;
          } else if (event.key === 'Home') {
            nextIndex = 0;
          } else if (event.key === 'End') {
            nextIndex = options.length - 1;
          } else {
            return;
          }

          event.preventDefault();
          var next = options[nextIndex];
          var mode = next.dataset.themeOption;
          if (!mode || !isValidMode(mode)) return;
          applyTheme(mode, true);
          next.focus();
        });

        if (mediaQuery) {
          mediaQuery.addEventListener('change', function () {
            if (readThemeMode() === 'auto') applyTheme('auto', false);
          });
        }
      })();
    </script>

    {
      /* Scroll-reveal + Umami scroll tracking (minimal vanilla JS, no framework) */
    }
    <script is:inline>
      // IntersectionObserver for [data-reveal] elements
      (function () {
        var reveals = document.querySelectorAll('[data-reveal]');
        if (reveals.length === 0) return;

        // If IntersectionObserver isn't supported, show everything
        if (!('IntersectionObserver' in window)) {
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
        );

        reveals.forEach(function (el) {
          observer.observe(el);
        });
      })();

      // Umami scroll-depth tracking (50% and 90%)
      (function () {
        if (!window.umami) return;

        var fired50 = false;
        var fired90 = false;

        function onScroll() {
          var max = document.documentElement.scrollHeight - window.innerHeight;
          if (max <= 0) return;
          var scrolled = window.scrollY / max;
          if (!fired50 && scrolled >= 0.5) {
            fired50 = true;
            window.umami.track('scroll_50');
          }
          if (!fired90 && scrolled >= 0.9) {
            fired90 = true;
            window.umami.track('scroll_90');
            window.removeEventListener('scroll', onScroll);
          }
        }

        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
