---
/**
 * BaseLayout — HTML shell for Web Dev Studio by EUHUB.
 * Inter via Fontsource (self-hosted, no Google Fonts).
 * SEO metadata, OG/Twitter, JSON-LD, Umami, skip link, and global styles.
 *
 * Props:
 *  - title:       <title> text (suffixed with brand)
 *  - description: meta description
 *  - path:        canonical path (e.g. "/"); full URL derived from astro.site
 *  - locale:      'en' | 'sk' — sets <html lang>, og:locale, hreflang alternates
 *  - noindex:     set true on legal placeholder pages during review
 *  - ogImage:     path to OG image (defaults to /og.png or /sk/og.png)
 */
import type { Locale } from '../content/types';
import { getAlternatePath } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  path: string;
  locale?: Locale;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  path,
  locale = 'en',
  noindex = false,
  ogImage = locale === 'sk' ? '/sk/og.png' : '/og.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://web-dev-studio.com');
const canonical = new URL(path, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const fullTitle =
  title === 'Web Dev Studio by EUHUB'
    ? title
    : `${title} — Web Dev Studio by EUHUB`;

// hreflang alternate URLs
const alternateEn = new URL(getAlternatePath(new URL(path, siteUrl), 'en'), siteUrl).href;
const alternateSk = new URL(getAlternatePath(new URL(path, siteUrl), 'sk'), siteUrl).href;

// Locale-specific metadata
const htmlLang = locale;
const ogLocale = locale === 'sk' ? 'sk_SK' : 'en_GB';

// Umami (cookieless, EU/Frankfurt). PUBLIC_ env vars are safe to inline.
const umamiScript = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

// JSON-LD: Organization + ProfessionalService (combined in one graph)
// Global styles — Tailwind v4 + Inter via Fontsource (self-hosted)
import '../styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Web Dev Studio by EUHUB',
      url: siteUrl.href,
      inLanguage: locale,
      parentOrganization: {
        '@type': 'Organization',
        name: 'EUHUB.CO',
        url: 'https://euhub.co',
      },
      areaServed: 'EU',
      knowsAbout: [
        'Web development',
        'Web applications',
        'AI-integrated interfaces',
        'API integration',
        'DevOps',
      ],
    },
    {
      '@type': 'ProfessionalService',
      name: 'Web Dev Studio by EUHUB',
      url: siteUrl.href,
      areaServed: 'EU',
      serviceType: 'Web development, web applications, AI-ready interfaces',
      offers: {
        '@type': 'Offer',
        itemOffered: 'Technical Web Audit',
      },
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1b4dff" />
    <meta name="generator" content={Astro.generator} />

    {
      /* No-FOUC theme script — runs before paint to set .dark on <html>.
        Order matters: this must execute before the body renders.
        localStorage 'theme' takes precedence; falls back to prefers-color-scheme. */
    }
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)',
          ).matches;
          var dark = stored ? stored === 'dark' : prefersDark;
          if (dark) document.documentElement.classList.add('dark');
          // Mark ready for smooth transitions after first paint
          requestAnimationFrame(function () {
            document.documentElement.classList.add('theme-ready');
          });
        } catch (e) {
          /* localStorage may be unavailable (private mode); ignore */
        }
      })();
    </script>

    {/* Auto-redirect Slovak browsers to /sk/ (EN pages only) */}
    {locale === 'en' && (
      <script is:inline>
        (function () {
          try {
            if (location.pathname.startsWith('/sk/')) return;
            if (localStorage.getItem('i18n-choice')) return;
            if (new URLSearchParams(location.search).has('no-redirect')) return;
            var langs = navigator.languages || [navigator.language];
            var isSk = langs.some(function (l) {
              return l.toLowerCase().startsWith('sk');
            });
            if (isSk) {
              localStorage.setItem('i18n-choice', 'sk');
              var skPath = '/sk' + location.pathname + location.search + location.hash;
              location.replace(skPath);
            }
          } catch (e) {
            /* ignore */
          }
        })();
      </script>
    )}

    {/* Canonical + robots */}
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* hreflang alternate links */}
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="sk" href={alternateSk} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    {/* Primary meta */}
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Web Dev Studio by EUHUB" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD structured data */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    {/* Umami — cookieless analytics (EU/Frankfurt). Loaded with defer. */}
    {
      umamiScript && umamiId && (
        <script is:inline src={umamiScript} data-website-id={umamiId} defer />
      )
    }

    {/* Global styles are imported in the frontmatter (Tailwind v4 + Inter) */}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-md focus:bg-surface focus:px-4 focus:py-2 focus:shadow-card focus:ring-2 focus:ring-brand"
    >
      Skip to content
    </a>
    <slot />

    {
      /* Scroll-reveal + Umami scroll tracking (minimal vanilla JS, no framework) */
    }
    <script is:inline>
      // IntersectionObserver for [data-reveal] elements
      (function () {
        var reveals = document.querySelectorAll('[data-reveal]');
        if (reveals.length === 0) return;

        // If IntersectionObserver isn't supported, show everything
        if (!('IntersectionObserver' in window)) {
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
        );

        reveals.forEach(function (el) {
          observer.observe(el);
        });
      })();

      // Umami scroll-depth tracking (50% and 90%)
      (function () {
        if (!window.umami) return;

        var fired50 = false;
        var fired90 = false;

        function onScroll() {
          var max = document.documentElement.scrollHeight - window.innerHeight;
          if (max <= 0) return;
          var scrolled = window.scrollY / max;
          if (!fired50 && scrolled >= 0.5) {
            fired50 = true;
            window.umami.track('scroll_50');
          }
          if (!fired90 && scrolled >= 0.9) {
            fired90 = true;
            window.umami.track('scroll_90');
            window.removeEventListener('scroll', onScroll);
          }
        }

        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
