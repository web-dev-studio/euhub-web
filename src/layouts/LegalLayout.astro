---
/**
 * Legal layout — shared by /privacy/, /cookies/, /terms/ (EN + SK).
 * Renders legal content with proper heading hierarchy.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Container from '../components/ui/Container.astro';
import type { LegalContent, Locale } from '../content/types';

interface Props {
  content: LegalContent;
  path: string;
  locale?: Locale;
}

const { content, path, locale = 'en' } = Astro.props;

const backLink = locale === 'sk' ? '/sk/' : '/';
const backLabel = locale === 'sk' ? '← Späť na domov' : '← Back to home';
const updatedLabel = locale === 'sk' ? 'Aktualizované:' : 'Last updated:';
---

<BaseLayout
  title={content.title}
  description={`${content.title} — Build with EUHub`}
  path={path}
  locale={locale}
  noindex={false}
>
  <Header locale={locale} />
  <main id="main">
    <div
      class="border-b border-(--color-border-subtle) bg-surface-sunken py-12"
    >
      <Container size="md">
        <h1
          class="font-heading text-h2 font-bold tracking-tight text-(--color-text-primary)"
        >
          {content.title}
        </h1>
        <p class="mt-2 text-sm text-(--color-text-secondary)">
          {updatedLabel}
          {content.lastUpdated}
        </p>
      </Container>
    </div>
    <Container size="md" class="py-12 md:py-16">
      <div class="space-y-6">
        {
          content.body.map((paragraph, i) => (
            <p
              class="text-sm leading-relaxed text-(--color-text-secondary) md:text-base"
              id={`section-${i}`}
            >
              {paragraph}
            </p>
          ))
        }
      </div>
      <div class="mt-12 border-t border-(--color-border-subtle) pt-6">
        <a
          href={backLink}
          class="text-sm font-medium text-primary-500 hover:underline"
        >
          {backLabel}
        </a>
      </div>
    </Container>
  </main>
  <Footer locale={locale} />
</BaseLayout>
