---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Web Dev Studio by EUHUB';
const description =
  'We build fast, secure, conversion-focused web platforms, web apps, and AI-ready interfaces for European businesses. Engineering-led, GDPR-aware, maintained long-term.';
---

<BaseLayout title={title} description={description} path="/">
  <main id="main">
    <div class="mx-auto max-w-3xl px-6 py-24">
      <h1 class="text-4xl font-bold tracking-tight text-ink">
        Web Dev Studio by EUHUB
      </h1>
      <p class="mt-4 text-lg text-ink-3">
        Scaffold verified. Full landing page build in progress.
      </p>
    </div>
  </main>
</BaseLayout>
