# ===========================================================================
# Web Dev Studio by EUHUB — environment variables
# Copy to `.env` for local dev. NEVER commit real secrets.
# On Cloudflare Workers, set secrets via `wrangler secret put <KEY>` or the
# dashboard. Runtime secrets are read via `astro:env` (access: "secret") or
# `Astro.locals.runtime.env`, NOT `import.meta.env`.
# ===========================================================================

# Canonical site URL (used for sitemap, OG tags, canonical links)
SITE_URL=https://web-dev-studio.com

# --- Contact form / webhook (SERVER-SIDE SECRETS) ---
# Destination for audit-request submissions (CRM intake, n8n, Zapier, etc.)
WEBHOOK_URL=
# Optional: bearer token for the webhook
WEBHOOK_TOKEN=

# --- Cloudflare Turnstile (spam protection) ---
# Public site key — exposed to the client (PUBLIC_ prefix required by Astro)
PUBLIC_TURNSTILE_SITE_KEY=
# Secret key — server-side only
TURNSTILE_SECRET_KEY=
# Cloudflare test keys for local dev / CI (always pass):
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA

# --- Umami Analytics (Umami Cloud, EU/Frankfurt) ---
# Both exposed to the client (rendered into the <script> tag)
PUBLIC_UMAMI_SCRIPT_URL=
PUBLIC_UMAMI_WEBSITE_ID=
